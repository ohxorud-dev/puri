---
import ProblemView from "../../components/ProblemView.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="문제 출제 - Puri">
  <div class="propose-container">
    <header class="propose-header">
      <div>
        <h1>문제 출제</h1>
        <p class="propose-desc">검토 후 관리자 승인을 거쳐 게시됩니다.</p>
      </div>
      <a href="/proposals/my" class="btn-list">내 제안 목록 →</a>
    </header>

    <div id="login-required" class="login-required" style="display:none;">
      <p>로그인이 필요합니다.</p>
      <a href="/login" class="btn-primary">로그인</a>
    </div>

    <form id="propose-form" class="propose-form" style="display:none;">
      <section class="form-section">
        <h2>출제 방식</h2>
        <div class="kind-picker" role="radiogroup" aria-label="출제 방식">
          <label class="kind-opt">
            <input type="radio" name="kind" value="general" checked />
            <span class="kind-card">
              <span class="kind-title">일반 문제 출제</span>
              <span class="kind-desc">커뮤니티에 공개되는 일반 문제</span>
            </span>
          </label>
          <label class="kind-opt">
            <input type="radio" name="kind" value="sale" />
            <span class="kind-card">
              <span class="kind-title">문제 판매</span>
              <span class="kind-desc">대회용 문제 제출</span>
            </span>
          </label>
        </div>
        <div id="sale-tier-wrap" class="field" style="display:none;">
          <label for="sale_tier">문제 난이도</label>
          <select id="sale_tier" name="sale_tier">
            <option value="1">플레티넘</option>
            <option value="2">다이아</option>
            <option value="3">루비</option>
          </select>
        </div>
      </section>

      <section class="form-section">
        <h2>기본 정보</h2>
        <div class="field">
          <label for="title">제목</label>
          <input type="text" id="title" name="title" required maxlength="200" />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="time_limit">시간 제한</label>
            <input type="text" id="time_limit" name="time_limit" value="1초" required maxlength="16" />
          </div>
          <div class="field">
            <label for="memory_limit">메모리 제한</label>
            <input type="text" id="memory_limit" name="memory_limit" value="128MB" required maxlength="16" />
          </div>
        </div>
      </section>

      <section class="form-section">
        <h2>문제 설명</h2>
        <p class="hint">Markdown 지원. 특별한 경우가 아니라면 입력/출력/제한 섹션을 포함하고 템플릿을 유지하세요.</p>
        <textarea id="statement_md" name="statement_md" rows="16" required>## 문제


## 입력


## 출력

</textarea>
      </section>

      <section class="form-section">
        <div class="section-head">
          <h2>예제</h2>
          <button type="button" id="add-example" class="btn-ghost">+ 예제 추가</button>
        </div>
        <div id="examples-list"></div>
      </section>

      <section class="form-section">
        <h2>전체 테스트케이스</h2>
        <p class="hint"><code>testcases.json</code> 업로드. 형식: <code>{`[{"input":"...","output":"..."}, ...]`}</code>. gzip 압축되어 전송됩니다.</p>
        <input type="file" id="testcases_file" accept="application/json,.json" />
        <div id="testcases_status" class="hint"></div>
      </section>

      <section class="form-section">
        <h2>레퍼런스 솔루션</h2>
        <div class="field-row">
          <div class="field">
            <label for="ref_lang">언어</label>
            <select id="ref_lang">
              <option value="1">C++</option>
              <option value="2">Python</option>
              <option value="3">Java</option>
              <option value="4">Go</option>
              <option value="5">JavaScript</option>
              <option value="6">Rust</option>
            </select>
          </div>
        </div>
        <textarea id="ref_source" rows="12" placeholder="정답 솔루션 소스코드" required></textarea>
      </section>

      <div class="actions">
        <button type="button" id="save-draft" class="btn-secondary">초안 저장</button>
        <button type="button" id="preview-btn" class="btn-secondary">문제 미리보기</button>
        <button type="button" id="submit-btn" class="btn-primary">제출 (예제 검증)</button>
      </div>

      <div id="status-msg" class="status-msg" style="display:none;"></div>
      <div id="validation-panel" class="validation-panel" style="display:none;"></div>

      <div id="preview-modal" class="preview-modal" style="display:none;" role="dialog" aria-modal="true" aria-label="문제 미리보기">
        <div class="preview-backdrop"></div>
        <div class="preview-dialog">
          <header class="preview-head">
            <h2>문제 미리보기</h2>
            <button type="button" id="preview-close" class="btn-ghost" aria-label="닫기">✕</button>
          </header>
          <div id="preview-body" class="preview-body">
            <ProblemView problemId="00000" />
          </div>
        </div>
      </div>
    </form>

  </div>
</BaseLayout>

<script>
  import { proposalClient } from '../../lib/api';
  import { isLoggedIn } from '../../lib/auth';

  const loginRequired = document.getElementById('login-required')!;
  const form = document.getElementById('propose-form')!;

  (async () => {
    if (!(await isLoggedIn())) {
      loginRequired.style.display = 'block';
      return;
    }
    form.style.display = '';
    init();
  })();

  function init() {

  let proposalId: bigint | null = null;
  const urlParams = new URLSearchParams(window.location.search);
  const idParam = urlParams.get('id');
  if (idParam) proposalId = BigInt(idParam);

  let testcasesGz: Uint8Array | null = null;

  const titleEl = document.getElementById('title') as HTMLInputElement;
  const stmtEl = document.getElementById('statement_md') as HTMLTextAreaElement;
  const tlEl = document.getElementById('time_limit') as HTMLInputElement;
  const mlEl = document.getElementById('memory_limit') as HTMLInputElement;
  const langEl = document.getElementById('ref_lang') as HTMLSelectElement;
  const srcEl = document.getElementById('ref_source') as HTMLTextAreaElement;
  const tcFileEl = document.getElementById('testcases_file') as HTMLInputElement;
  const tcStatusEl = document.getElementById('testcases_status')!;
  const examplesList = document.getElementById('examples-list')!;
  const statusMsg = document.getElementById('status-msg')!;
  const validationPanel = document.getElementById('validation-panel')!;
  const addExBtn = document.getElementById('add-example') as HTMLButtonElement;
  const saveBtn = document.getElementById('save-draft') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const previewBtn = document.getElementById('preview-btn') as HTMLButtonElement;
  const previewModal = document.getElementById('preview-modal') as HTMLDivElement;
  const previewBody = document.getElementById('preview-body') as HTMLDivElement;
  const previewClose = document.getElementById('preview-close') as HTMLButtonElement;
  const kindRadios = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="kind"]'));
  const saleTierWrap = document.getElementById('sale-tier-wrap') as HTMLDivElement;
  const saleTierEl = document.getElementById('sale_tier') as HTMLSelectElement;

  function currentKind(): 'general' | 'sale' {
    return (kindRadios.find(r => r.checked)?.value as 'general' | 'sale') || 'general';
  }
  function syncSaleTierVisibility() {
    saleTierWrap.style.display = currentKind() === 'sale' ? '' : 'none';
  }
  function lockKindRadios() {
    kindRadios.forEach(r => { r.disabled = true; });
  }
  kindRadios.forEach(r => r.addEventListener('change', syncSaleTierVisibility));
  syncSaleTierVisibility();

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderExampleRow(input = '', output = '') {
    const row = document.createElement('div');
    row.className = 'example-row';
    row.innerHTML = `
      <div class="ex-cols">
        <div><label>입력</label><textarea class="ex-input" rows="4">${escapeHtml(input)}</textarea></div>
        <div><label>출력</label><textarea class="ex-output" rows="4">${escapeHtml(output)}</textarea></div>
      </div>
      <button type="button" class="btn-ghost btn-del">삭제</button>
    `;
    row.querySelector('.btn-del')!.addEventListener('click', () => row.remove());
    examplesList.appendChild(row);
  }

  function collectExamples() {
    return Array.from(examplesList.querySelectorAll('.example-row')).map(row => ({
      input: (row.querySelector('.ex-input') as HTMLTextAreaElement).value,
      output: (row.querySelector('.ex-output') as HTMLTextAreaElement).value,
    })).filter(ex => ex.input || ex.output);
  }

  addExBtn.addEventListener('click', () => renderExampleRow());
  renderExampleRow();

  async function gzipJson(text: string) {
    const cs = new (window as any).CompressionStream('gzip');
    const blob = new Blob([text]);
    const stream = blob.stream().pipeThrough(cs);
    const buf = await new Response(stream).arrayBuffer();
    return new Uint8Array(buf);
  }

  tcFileEl.addEventListener('change', async () => {
    const file = tcFileEl.files?.[0];
    if (!file) { testcasesGz = null; tcStatusEl.textContent = ''; return; }
    try {
      const text = await file.text();
      const parsed = JSON.parse(text);
      if (!Array.isArray(parsed)) throw new Error('배열이 아닙니다');
      testcasesGz = await gzipJson(text);
      tcStatusEl.textContent = `${parsed.length}개 케이스, 압축 후 ${(testcasesGz.byteLength / 1024).toFixed(1)}KB`;
    } catch (err: any) {
      testcasesGz = null;
      tcStatusEl.textContent = `파싱 실패: ${err.message}`;
    }
  });

  function showStatus(type: 'ok' | 'err' | 'info', msg: string) {
    statusMsg.style.display = 'block';
    statusMsg.className = `status-msg status-${type}`;
    statusMsg.textContent = msg;
  }

  async function ensureProposal(): Promise<bigint> {
    if (proposalId) return proposalId;
    const title = titleEl.value.trim() || '제목 없는 제안';
    const kind = currentKind();
    const createReq: any = { title, kind: kind === 'sale' ? 2 : 1 };
    if (kind === 'sale') createReq.saleTier = parseInt(saleTierEl.value, 10);
    const resp = await proposalClient.createProposal(createReq);
    proposalId = resp.proposalId;
    lockKindRadios();
    const newUrl = new URL(window.location.href);
    newUrl.searchParams.set('id', proposalId.toString());
    window.history.replaceState({}, '', newUrl);
    return proposalId;
  }

  async function pushUpdate(includeTestcases: boolean) {
    const id = await ensureProposal();
    const examples = collectExamples();
    const update: any = {
      proposalId: id,
      title: titleEl.value,
      statementMd: stmtEl.value,
      timeLimit: tlEl.value,
      memoryLimit: mlEl.value,
      referenceSolutionLanguage: parseInt(langEl.value, 10),
      referenceSolutionSource: srcEl.value,
      examples,
    };
    if (includeTestcases && testcasesGz) update.testcasesGz = testcasesGz;
    if (currentKind() === 'sale') update.saleTier = parseInt(saleTierEl.value, 10);
    await proposalClient.updateProposal(update);
  }

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    validationPanel.style.display = 'none';
    try {
      await pushUpdate(true);
      showStatus('ok', '초안 저장됨');
    } catch (err: any) {
      showStatus('err', `저장 실패: ${err.message}`);
    } finally {
      saveBtn.disabled = false;
    }
  });

  function renderMarkdown(src: string): string {
    const lines = src.replace(/\r\n/g, '\n').split('\n');
    const out: string[] = [];
    let para: string[] = [];
    const flush = () => {
      if (para.length) { out.push(`<p>${para.join('<br/>')}</p>`); para = []; }
    };
    for (const raw of lines) {
      const line = raw;
      const h = /^(#{1,6})\s+(.*)$/.exec(line);
      if (h) {
        flush();
        const lvl = h[1].length;
        out.push(`<h${lvl}>${escapeHtml(h[2])}</h${lvl}>`);
        continue;
      }
      if (!line.trim()) { flush(); continue; }
      para.push(escapeHtml(line));
    }
    flush();
    return out.join('\n');
  }

  function $pv<T extends Element = HTMLElement>(sel: string): T {
    return previewBody.querySelector(sel) as T;
  }

  const TIER_STYLES: Record<string, { label: string; bg: string }> = {
    platinum: { label: 'Platinum', bg: 'linear-gradient(135deg, #34d399, #059669)' },
    diamond:  { label: 'Diamond',  bg: 'linear-gradient(135deg, #38bdf8, #0284c7)' },
    ruby:     { label: 'Ruby',     bg: 'linear-gradient(135deg, #f43f5e, #be123c)' },
  };

  function openPreview() {
    const title = titleEl.value.trim() || '(제목 없음)';
    const kind = currentKind();

    $pv('[data-pv-title]').textContent = title;
    $pv('[data-pv-time]').textContent = tlEl.value.trim();
    $pv('[data-pv-memory]').textContent = mlEl.value.trim();

    const titleWrap = $pv('.problem-title');
    titleWrap.querySelectorAll('.tier-badge, .problem-tier-badge').forEach(n => n.remove());
    if (kind === 'sale') {
      const key = saleTierEl.options[saleTierEl.selectedIndex]?.value;
      const tierKey = key === '1' ? 'platinum' : key === '2' ? 'diamond' : 'ruby';
      const t = TIER_STYLES[tierKey];
      const badge = document.createElement('span');
      badge.className = 'tier-badge problem-tier-badge';
      badge.style.background = t.bg;
      badge.style.color = '#fff';
      badge.style.borderRadius = '6px';
      badge.style.padding = '0.3rem 0.8rem';
      badge.style.fontWeight = '700';
      badge.style.fontSize = '0.85rem';
      badge.textContent = t.label;
      titleWrap.appendChild(badge);
    }

    $pv('[data-pv-statement]').innerHTML = renderMarkdown(stmtEl.value);

    const examples = collectExamples();
    const wrap = $pv('[data-pv-examples-wrap]') as HTMLElement;
    const list = $pv('[data-pv-examples]');
    if (examples.length === 0) {
      wrap.style.display = 'none';
      list.innerHTML = '';
    } else {
      wrap.style.display = '';
      list.innerHTML = examples.map((ex, i) => `
        <div class="example-row">
          <div class="example-box">
            <div class="example-label">예제 입력 ${i + 1}</div>
            <pre class="example-code"><code>${escapeHtml(ex.input)}</code></pre>
          </div>
          <div class="example-box">
            <div class="example-label">예제 출력 ${i + 1}</div>
            <pre class="example-code"><code>${escapeHtml(ex.output)}</code></pre>
          </div>
        </div>`).join('');
    }

    // Re-wrap pre blocks (gutter + copy button) for newly injected markdown/examples.
    // Unwrap previously-enhanced blocks first so repeated previews don't double-wrap.
    previewBody.querySelectorAll('.clean-code-wrapper').forEach(w => {
      const pre = w.querySelector('pre');
      if (pre && w.parentNode) w.parentNode.insertBefore(pre, w);
      w.remove();
    });
    (window as any).__enhanceProblemView?.(previewBody);

    previewModal.style.display = '';
    document.body.style.overflow = 'hidden';
  }

  function closePreview() {
    previewModal.style.display = 'none';
    document.body.style.overflow = '';
  }

  previewBtn.addEventListener('click', openPreview);
  previewClose.addEventListener('click', closePreview);
  previewModal.querySelector('.preview-backdrop')!.addEventListener('click', closePreview);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && previewModal.style.display !== 'none') closePreview();
  });

  submitBtn.addEventListener('click', async () => {
    submitBtn.disabled = true;
    validationPanel.style.display = 'none';
    try {
      await pushUpdate(true);
      const id = await ensureProposal();
      showStatus('info', '레퍼런스 솔루션 실행 중...');
      const resp = await proposalClient.submitProposal({ proposalId: id });
      renderValidation(resp);
    } catch (err: any) {
      showStatus('err', `제출 실패: ${err.message}`);
    } finally {
      submitBtn.disabled = false;
    }
  });

  function statusLabel(n: number) {
    return ['미정','draft','submitted','reviewing','approved','rejected','published'][n] || 'unknown';
  }

  function renderValidation(resp: any) {
    const label = statusLabel(resp.status);
    const ok = label === 'submitted';
    showStatus(ok ? 'ok' : 'err', ok ? '제출 완료 — 모든 예제 통과' : `제출 실패 — 상태: ${label}`);
    let html = '';
    if (resp.reviewNotes) html += `<div class="notes">${escapeHtml(resp.reviewNotes)}</div>`;
    html += '<div class="val-list">';
    for (const v of resp.exampleValidationResult || []) {
      html += `<div class="val-item ${v.passed ? 'val-pass' : 'val-fail'}">
        <div class="val-head">
          <span class="val-badge">${v.passed ? '통과' : '실패'}</span>
          <span>예제 ${v.index}</span>
          <span class="val-time">${v.executionTimeMs}ms</span>
        </div>
        ${v.passed ? '' : `<div class="val-diff">
          <div><strong>기대</strong><pre>${escapeHtml(v.expectedOutput)}</pre></div>
          <div><strong>실제</strong><pre>${escapeHtml(v.actualOutput)}</pre></div>
        </div>`}
      </div>`;
    }
    html += '</div>';
    validationPanel.innerHTML = html;
    validationPanel.style.display = 'block';
  }

  async function loadExisting() {
    if (!proposalId) return;
    try {
      const resp = await proposalClient.getProposal({ proposalId });
      const p = resp.proposal!;
      titleEl.value = p.title;
      const kindVal = p.kind === 2 ? 'sale' : 'general';
      kindRadios.forEach(r => { r.checked = r.value === kindVal; });
      lockKindRadios();
      if (kindVal === 'sale' && p.saleTier) saleTierEl.value = String(p.saleTier);
      syncSaleTierVisibility();
      stmtEl.value = p.statementMd;
      tlEl.value = p.timeLimit;
      mlEl.value = p.memoryLimit;
      langEl.value = String(p.referenceSolutionLanguage || 1);
      srcEl.value = p.referenceSolutionSource;
      examplesList.innerHTML = '';
      for (const ex of p.examples || []) renderExampleRow(ex.input, ex.output);
      if (!p.examples?.length) renderExampleRow();
      if (p.exampleValidationResult?.length) renderValidation({
        status: p.status,
        reviewNotes: p.reviewNotes,
        exampleValidationResult: p.exampleValidationResult,
      });
    } catch (err: any) {
      showStatus('err', `불러오기 실패: ${err.message}`);
    }
  }
  loadExisting();
  }
</script>

<style is:global>
  .propose-container { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .propose-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 2rem; }
  .propose-header h1 { font-size: 2rem; margin: 0 0 0.3rem; letter-spacing: -0.02em; }
  .propose-desc { color: var(--color-text-muted); margin: 0; }
  .btn-list {
    padding: 0.6rem 1rem; border: 1.5px solid var(--color-border); border-radius: 8px;
    color: var(--color-text); font-weight: 600; text-decoration: none; font-size: 0.9rem;
    white-space: nowrap;
  }
  .btn-list:hover { background: var(--color-surface); }
  .propose-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .kind-picker { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin-bottom: 1rem; }
  .kind-opt { cursor: pointer; }
  .kind-opt input { position: absolute; opacity: 0; pointer-events: none; }
  .kind-card {
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: 1rem 1.1rem; border: 1.5px solid var(--color-border);
    border-radius: 10px; background: var(--color-bg);
    transition: border-color 0.15s, background 0.15s;
  }
  .kind-opt input:checked + .kind-card {
    border-color: var(--color-btn-1-bg);
    background: color-mix(in srgb, var(--color-btn-1-bg) 8%, var(--color-bg));
  }
  .kind-opt input:disabled + .kind-card { opacity: 0.65; cursor: not-allowed; }
  .kind-title { font-weight: 700; font-size: 0.98rem; }
  .kind-desc { font-size: 0.85rem; color: var(--color-text-muted); }
  .form-section {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 12px; padding: 1.5rem;
  }
  .form-section h2 { font-size: 1.15rem; margin: 0 0 1rem; font-weight: 700; }
  .section-head { display:flex; justify-content:space-between; align-items:center; margin-bottom: 0.5rem; }
  .section-head h2 { margin: 0; }
  .hint { font-size: 0.88rem; color: var(--color-text-muted); margin: 0.2rem 0 0.8rem; }
  .hint code { background: var(--color-bg); padding: 0.1em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.8rem; }
  .field label { font-weight: 600; font-size: 0.92rem; }
  .field input, .field select, textarea {
    width: 100%; box-sizing: border-box; padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--color-border); border-radius: 8px;
    background: var(--color-bg); color: var(--color-text); font-size: 0.95rem;
    font-family: inherit;
  }
  textarea { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .example-row { border: 1px solid var(--color-border); border-radius: 8px; padding: 1rem; margin-bottom: 0.8rem; background: var(--color-bg); }
  .ex-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin-bottom: 0.6rem; }
  .ex-cols label { font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 0.3rem; }
  .actions { display: flex; gap: 0.8rem; justify-content: flex-end; }
  .btn-primary, .btn-secondary, .btn-ghost {
    padding: 0.7rem 1.3rem; border-radius: 8px; font-weight: 600; cursor: pointer;
    font-size: 0.95rem; border: 1.5px solid var(--color-border); transition: all 0.15s;
  }
  .btn-primary { background: var(--color-btn-1-bg); color: var(--color-btn-1-text); border-color: transparent; }
  .btn-primary:hover { background: var(--color-btn-1-hover); }
  .btn-secondary { background: var(--color-surface); color: var(--color-text); }
