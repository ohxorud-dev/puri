---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { username } = Astro.params;
---
<BaseLayout title={`${username} - Puri`}>
  <div class="profile-container">
    <div id="profile-loading" style="text-align:center; padding:4rem; color:var(--color-text-muted);">불러오는 중...</div>
    <div id="profile-error" style="display:none; text-align:center; padding:4rem; color:var(--color-text-muted);"></div>
    <div id="profile-content" style="display:none;">
      <div class="profile-header">
        <div class="profile-avatar">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide-user"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="profile-info">
          <h1 class="profile-username"><span id="profile-username"></span></h1>
          <p class="profile-bio"><span id="profile-email"></span></p>
        </div>
      </div>

      <div class="profile-grid">
        <div class="stats-card">
          <h2 class="card-title">프로필 정보</h2>
          <div class="stats-row">
            <div class="stat-item">
              <span class="stat-label">아이디</span>
              <span class="stat-value" id="stat-username" style="font-size:1.3rem;"></span>
            </div>
            <div class="stat-item" id="stat-email-item" style="display:none;">
              <span class="stat-label">이메일</span>
              <span class="stat-value" id="stat-email" style="font-size:1.3rem;"></span>
            </div>
            <div class="stat-item">
              <span class="stat-label">표시 이름</span>
              <span class="stat-value" id="stat-displayname" style="font-size:1.3rem;">-</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">BOJ 핸들</span>
              <span class="stat-value" id="stat-bojhandle" style="font-size:1.3rem;">-</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ username }}>
  window.__PROFILE_USERNAME__ = username;
</script>

<script>
  import { getUser } from '../../lib/auth';
  import { userClient } from '../../lib/api';

  const requested = (window as any).__PROFILE_USERNAME__ as string;

  async function loadProfile() {
    const loadingEl = document.getElementById('profile-loading')!;
    const errorEl = document.getElementById('profile-error')!;
    const contentEl = document.getElementById('profile-content')!;

    let target;
    let me;
    try { me = await getUser(); } catch { me = null; }

    try {
      const resp = await userClient.getUserByUsername({ username: requested });
      target = resp.user;
    } catch {
      loadingEl.style.display = 'none';
      errorEl.style.display = '';
      errorEl.innerHTML = '<p>사용자를 찾을 수 없습니다.</p>';
      return;
    }

    if (!target) {
      loadingEl.style.display = 'none';
      errorEl.style.display = '';
      errorEl.innerHTML = '<p>사용자를 찾을 수 없습니다.</p>';
      return;
    }

    loadingEl.style.display = 'none';
    contentEl.style.display = '';

    document.getElementById('profile-username')!.textContent = target.username;
    document.getElementById('profile-email')!.textContent = target.email || '';
    document.getElementById('stat-username')!.textContent = target.username;
    if (target.email) {
      document.getElementById('stat-email-item')!.style.display = '';
      document.getElementById('stat-email')!.textContent = target.email;
    }
    document.getElementById('stat-displayname')!.textContent = target.displayName || '-';
    document.getElementById('stat-bojhandle')!.textContent = target.bojHandle || '-';
  }

  loadProfile();
</script>

<style>
  .profile-container { max-width: 1200px; margin: 4rem auto; padding: 0 1.5rem; }
  .profile-header { display: flex; align-items: center; gap: 2rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--color-border); margin-bottom: 3rem; }
  .profile-avatar { width: 90px; height: 90px; border-radius: 50%; background: var(--color-surface); border: 2px solid var(--color-border); display: flex; align-items: center; justify-content: center; color: var(--color-text-muted); }
  .profile-info { flex: 1; }
  .profile-username { font-size: 2.2rem; font-weight: 800; margin: 0 0 0.5rem 0; color: var(--color-text); display: flex; align-items: center; gap: 1rem; }
  .profile-bio { font-size: 1.05rem; color: var(--color-text-muted); margin: 0; }
  .profile-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; }
  @media (max-width: 800px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-header { flex-direction: column; text-align: center; }
  }
  .stats-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem; height: fit-content; }
  .card-title { font-size: 1.3rem; font-weight: 700; margin: 0 0 1.5rem 0; color: var(--color-text); }
  .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .stat-item { display: flex; flex-direction: column; gap: 0.5rem; background: var(--color-bg); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-border); }
  .stat-label { font-size: 0.9rem; font-weight: 600; color: var(--color-text-muted); }
  .stat-value { font-size: 2rem; font-weight: 800; color: var(--color-text); }
</style>
