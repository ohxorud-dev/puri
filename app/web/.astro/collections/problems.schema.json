{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "time_limit": {
      "type": "string"
    },
    "memory_limit": {
      "type": "string"
    },
    "tier": {
      "type": "string"
    },
    "step": {
      "type": "string"
    },
    "source": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "string"
        }
      ]
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "input": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        },
        "required": [
          "input",
          "output"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "time_limit",
    "memory_limit"
  ]
}