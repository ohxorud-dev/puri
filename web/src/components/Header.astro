---
const { fullWidth = false } = Astro.props;
---
<nav class="navbar">
  <div class={`navbar-container ${fullWidth ? 'full-width' : ''}`}>
    <a href="/" class="navbar-brand">Puri</a>
    
    <div class="navbar-desktop">
      <ul class="navbar-nav">
        <li><a href="/steps">단계</a></li>
        <li><a href="/problems">문제</a></li>
        <li><a href="/source">출처</a></li>
        <li><a href="/status">채점 현황</a></li>
        <li><a href="/ranking">랭킹</a></li>
        <li><a href="/community/general">커뮤니티</a></li>
        <li><a href="/proposals/my">문제 출제</a></li>
        <li class="auth-separator"></li>
        <li class="nav-auth-login"><a href="/login" class="nav-login">로그인</a></li>
        <li class="nav-auth-profile" style="display:none;"><a href="/profile">프로필</a></li>
      </ul>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>
    </div>

    <div class="navbar-mobile-toggle">
      <button id="mobile-menu-btn" class="menu-btn" aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>
</nav>

<div id="mobile-sidebar" class="sidebar">
  <div class="sidebar-header">
    <a href="/" class="navbar-brand">Puri</a>
    <button id="close-sidebar-btn" class="close-btn" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="sidebar-content">
    <ul class="sidebar-nav">
      <li><a href="/steps">단계</a></li>
      <li><a href="/problems">문제</a></li>
      <li><a href="/source">출처</a></li>
      <li><a href="/status">채점 현황</a></li>
      <li><a href="/ranking">랭킹</a></li>
      <li><a href="/community/general">커뮤니티</a></li>
      <li><a href="/proposals/my">문제 출제</a></li>
      <li class="sidebar-separator"></li>
      <li class="nav-auth-login"><a href="/login" class="nav-login">로그인</a></li>
      <li class="nav-auth-profile" style="display:none;"><a href="/profile">프로필</a></li>
    </ul>
    
    <div class="sidebar-footer">
      <button id="mobile-theme-toggle" class="mobile-theme-toggle" aria-label="Toggle dark mode">
        <span class="theme-label">테마 변경</span>
        <div class="theme-icons">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </div>
      </button>
    </div>
  </div>
</div>

<div id="sidebar-overlay" class="sidebar-overlay"></div>

<script>
  import { isLoggedIn } from '../lib/auth';

  async function updateAuth() {
    const loggedIn = await isLoggedIn();
    const loginEls = document.querySelectorAll<HTMLElement>('.nav-auth-login');
    const profileEls = document.querySelectorAll<HTMLElement>('.nav-auth-profile');

    loginEls.forEach(el => el.style.display = loggedIn ? 'none' : '');
    profileEls.forEach(el => el.style.display = loggedIn ? '' : 'none');
  }

  updateAuth();

  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-sidebar-btn');
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  function openSidebar() {
    sidebar.classList.add('active');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar.classList.remove('active');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  overlay?.addEventListener('click', closeSidebar);
</script>

<script is:inline>
  function setupTheme(btnId) {
    document.getElementById(btnId)?.addEventListener('click', () => {
      const htmlObj = document.documentElement;
      const currentTheme = htmlObj.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      htmlObj.setAttribute('data-theme', newTheme);
      window.localStorage.setItem('theme', newTheme);
    });
  }

  setupTheme('theme-toggle');
  setupTheme('mobile-theme-toggle');
</script>

<style is:global>
  .navbar {
    background: var(--color-nav-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0 1.5rem;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .navbar-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    height: 64px;
    justify-content: space-between;
  }
  .navbar-container.full-width {
    max-width: 100%;
    padding: 0 1rem;
  }
  .navbar-desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .navbar-brand {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .navbar-brand:hover {
    opacity: 0.8;
  }
  .navbar-nav {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 1.8rem;
  }
  .navbar-nav li a {
    color: var(--color-text-muted);
    font-size: 1rem;
    font-weight: 600;
    transition: color 0.2s;
  }
  .navbar-nav li a:hover {
    color: var(--color-text);
  }
  .auth-separator {
    width: 1px;
    height: 16px;
    background-color: var(--color-border);
    margin: 0 0.2rem;
    align-self: center;
  }
  .nav-login {
    font-weight: 600;
  }

  /* Mobile Toggle */
  .navbar-mobile-toggle {
    display: none;
  }
  .menu-btn {
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    transition: background-color 0.2s;
  }
  .menu-btn:hover {
    background-color: var(--color-surface);
  }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0;
    right: -300px;
    width: 300px;
    height: 100vh;
    background: var(--color-nav-bg);
    z-index: 1001;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -5px 0 15px rgba(0, 0, 0, 0.1);
  }
  .sidebar.active {
    transform: translateX(-300px);
  }
  .sidebar-header {
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
  }
  .close-btn {
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
  }
  .sidebar-content {
    flex: 1;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .sidebar-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-nav li a {
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 600;
    text-decoration: none;
    display: block;
    transition: color 0.2s;
  }
  .sidebar-separator {
    height: 1px;
    background-color: var(--color-border);
    margin: 0.5rem 0;
  }
  .sidebar-footer {
    margin-top: auto;
    padding-top: 2rem;
  }
  .mobile-theme-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    color: var(--color-text);
    cursor: pointer;
  }
  .theme-label {
    font-weight: 600;
  }
  .theme-icons {
    display: flex;
    align-items: center;
  }

  .sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(2px);
  }
  .sidebar-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .theme-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 1.3rem;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background-color 0.3s;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
  }
  .theme-toggle:hover {
    background-color: var(--color-surface);
  }
  
  .theme-toggle > svg {
    width: 22px;
    height: 22px;
  }

  @media (max-width: 768px) {
    .navbar-desktop {
      display: none;
    }
    .navbar-mobile-toggle {
      display: block;
    }
    .navbar {
      padding: 0 1rem;
    }
  }

  /* Default (Light Mode) */
  :root[data-theme='light'] .icon-sun, 
  :root:not([data-theme='dark']) .icon-sun {
    display: none;
  }
  :root[data-theme='light'] .icon-moon,
  :root:not([data-theme='dark']) .icon-moon {
    display: block;
  }

  /* Dark Mode */
  :root[data-theme='dark'] .icon-sun {
    display: block;
  }
  :root[data-theme='dark'] .icon-moon {
    display: none;
  }
</style>
